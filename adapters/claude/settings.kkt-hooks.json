{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell|Edit|MultiEdit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "kkt",
            "args": ["hook", "pre-tool", "--agent", "claude"],
            "timeout": 30,
            "statusMessage": "Checking KKT guardrails"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|PowerShell|Edit|MultiEdit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "kkt",
            "args": ["hook", "post-tool", "--agent", "claude"],
            "timeout": 30,
            "statusMessage": "Checking KKT guardrails"
          }
        ]
      }
    ]
  }
}
